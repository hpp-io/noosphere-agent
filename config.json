{
  "forwardStats": true,
  "manageContainers": true,
  "startupWait": 5.0,
  "server": {
    "port": 8080,
    "rateLimit": {
      "numRequests": 100,
      "period": 60
    }
  },
  "chain": {
    "enabled": true,
    "rpcUrl": "http://localhost:8545",
    "trailHeadBlocks": 10,
    "registryAddress": "0x1234567890123456789012345678901234567890",
    "wallet": {
      "maxGasLimit": 1000000,
      "privateKey": "your-private-key",
      "paymentAddress": "0xabcdefabcdefabcdefabcdefabcdefabcdefabcd",
      "allowedSimErrors": ["execution reverted", "out of gas"]
    },
    "snapshotSync": {
      "sleep": 1.0,
      "batchSize": 100,
      "startingSubId": 0,
      "syncPeriod": 300.0
    }
  },
  "docker": {
    "username": "your-docker-username",
    "password": "your-docker-password"
  },
  "containers": [
    {
      "id": "hello-world",
      "image": "ritualnetwork/hello-world-infernet:latest",
      "external": true,
      "port": "3000",
      "allowedDelegateAddresses": [],
      "allowedAddresses": [],
      "allowedIps": [],
      "command": "--bind=0.0.0.0:3000 --workers=2",
      "env": {},
      "volumes": [],
      "acceptedPayments": {},
      "generatesProofs": false
    }
  ]
}
