{
  "forwardStats": true,
  "manageContainers": true,
  "startupWait": 5.0,
  "server": {
    "port": 8080,
    "rateLimit": {
      "numRequests": 100,
      "period": 60
    }
  },
  "chain": {
    "enabled": true,
    "rpcUrl": "http://localhost:8545",
    "trailHeadBlocks": 10,
    "routerAddress": "0x2279B7A0a67DB372996a5FaB50D91eAA73d2eBe6",
    "wallet": {
      "maxGasLimit": 1000000,
      "privateKey": "0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80",
      "paymentAddress": "",
      "allowedSimErrors": ["execution reverted", "out of gas"]
    },
    "snapshotSync": {
      "sleep": 1.0,
      "batchSize": 100,
      "startingSubId": 0,
      "syncPeriod": 300.0
    },
    "connection": {
      "timeout": 30000,
      "readTimeout": 60000,
      "writeTimeout": 60000
    },
    "gasConfig": {
      "priceMultiplier": 1.2,
      "limitMultiplier": 1.3
    }
  },
  "docker": {
    "username": "your-docker-username",
    "password": "your-docker-password"
  },
  "containers": [
    {
      "id": "hello-world",
      "image": "ritualnetwork/hello-world-infernet:latest",
      "external": true,
      "port": "3000",
      "allowedDelegateAddresses": [],
      "allowedAddresses": [],
      "allowedIps": [],
      "command": "--bind=0.0.0.0:3000 --workers=2",
      "env": {},
      "volumes": [],
      "acceptedPayments": {},
      "generatesProofs": false
    }
  ]
}
